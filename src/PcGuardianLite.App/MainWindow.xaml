<Window x:Class="PcGuardianLite.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PcGuardianLite"
        Width="430"
        Height="730"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="CyberTextPrimaryBrush" Color="#F3F7FF" />
        <SolidColorBrush x:Key="CyberTextSecondaryBrush" Color="#9DB7E8" />
        <SolidColorBrush x:Key="CyberBaseBrush" Color="#07111F" />
        <SolidColorBrush x:Key="CyberCyanBrush" Color="#2DE2FF" />
        <SolidColorBrush x:Key="CyberVioletBrush" Color="#A855F7" />
        <SolidColorBrush x:Key="CyberPanelBorderBrush" Color="#2457B7" />
        <SolidColorBrush x:Key="CyberCardBorderBrush" Color="#2E6BEA" />

        <LinearGradientBrush x:Key="CyberPanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F507111F" Offset="0" />
            <GradientStop Color="#F30B1630" Offset="0.52" />
            <GradientStop Color="#F2140B2D" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CyberCardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D90C1B39" Offset="0" />
            <GradientStop Color="#CC111D3F" Offset="0.58" />
            <GradientStop Color="#B5161239" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CyberActionBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2563EB" Offset="0" />
            <GradientStop Color="#7C3AED" Offset="1" />
        </LinearGradientBrush>

        <RadialGradientBrush x:Key="CyberBallBrush" GradientOrigin="0.35,0.28" Center="0.5,0.5" RadiusX="0.72" RadiusY="0.72">
            <GradientStop Color="#182A62" Offset="0" />
            <GradientStop Color="#0E1B3C" Offset="0.5" />
            <GradientStop Color="#050B18" Offset="1" />
        </RadialGradientBrush>

        <Storyboard x:Key="CyberPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="BallPulseScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="1.035"
                             Duration="0:0:1.6" />
            <DoubleAnimation Storyboard.TargetName="BallPulseScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="1.035"
                             Duration="0:0:1.6" />
        </Storyboard>

        <Style x:Key="CyberSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="CyberMetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CyberTextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="CyberMetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="CyberMetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CyberCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CyberCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#2DE2FF" Opacity="0.16" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#C084FC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CyberInfoPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#B5121A35" />
            <Setter Property="BorderBrush" Value="#3659D4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,2,0,10" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,7,0,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="Background" Value="{StaticResource CyberActionBrush}" />
            <Setter Property="BorderBrush" Value="#38BDF8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E879F9" />
                                <Setter Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,14,6" />
        </Style>

        <Style x:Key="CyberTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="CyberTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource CyberTextSecondaryBrush}" />
            <Setter Property="Background" Value="#66101A34" />
            <Setter Property="BorderBrush" Value="#3659D4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="11,6" />
            <Setter Property="Margin" Value="0,0,6,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
                                <Setter TargetName="TabBorder" Property="Background" Value="#AA173071" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#2DE2FF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#C084FC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
            <Border x:Name="FloatingBall"
                    Width="112"
                    Height="112"
                    HorizontalAlignment="Right"
                    CornerRadius="56"
                    Background="{StaticResource CyberBallBrush}"
                    BorderBrush="{StaticResource CyberCyanBrush}"
                    BorderThickness="2"
                    RenderTransformOrigin="0.5,0.5"
                    MouseLeftButtonDown="FloatingBall_MouseLeftButtonDown"
                    MouseMove="FloatingBall_MouseMove"
                    MouseLeftButtonUp="FloatingBall_MouseLeftButtonUp">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="BallPulseScale" />
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource CyberPulseStoryboard}" />
                    </EventTrigger>
                </Border.Triggers>
                <Border.ContextMenu>
                    <ContextMenu Opened="FloatingBallContextMenu_Opened">
                        <MenuItem x:Name="PanelToggleMenuItem"
                                  Header="打开面板"
                                  Click="PanelToggleMenuItem_Click" />
                        <MenuItem x:Name="MonitorToggleMenuItem"
                                  Header="暂停监控"
                                  Click="MonitorToggleMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="显示内存"
                                  Click="DisplayMemoryMenuItem_Click" />
                        <MenuItem Header="显示 CPU"
                                  Click="DisplayCpuMenuItem_Click" />
                        <MenuItem Header="显示网速"
                                  Click="DisplayNetworkMenuItem_Click" />
                        <MenuItem Header="自动轮播"
                                  Click="DisplayAutoMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="透明度 95%"
                                  Click="Opacity95MenuItem_Click" />
                        <MenuItem Header="透明度 75%"
                                  Click="Opacity75MenuItem_Click" />
                        <MenuItem Header="透明度 55%"
                                  Click="Opacity55MenuItem_Click" />
                        <Separator />
                        <MenuItem Header="隐藏到托盘"
                                  Click="HideToTrayMenuItem_Click" />
                        <MenuItem Header="退出程序"
                                  Click="Exit_Click" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#2DE2FF" Opacity="0.55" />
                </Border.Effect>
                <Grid>
                    <Ellipse Stroke="#55A855F7"
                             StrokeThickness="1"
                             Margin="9" />
                    <Ellipse Stroke="#332DE2FF"
                             StrokeThickness="1"
                             Margin="18" />
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="96">
                        <TextBlock x:Name="BallMemoryText"
                                   Text="内存 --"
                                   Foreground="#F8FAFC"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <Border Height="1"
                                Margin="12,7"
                                Background="#882DE2FF" />
                        <TextBlock x:Name="BallDownloadText"
                                   Text="下载 --"
                                   Foreground="#BFE7FF"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="DetailPanel"
                    Width="410"
                    MaxHeight="600"
                    Margin="0,10,0,0"
                    Padding="16"
                    CornerRadius="8"
                    Background="{StaticResource CyberPanelBrush}"
                    BorderBrush="{StaticResource CyberPanelBorderBrush}"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#0EA5E9" Opacity="0.36" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="电脑管家"
                                       Foreground="{StaticResource CyberTextPrimaryBrush}"
                                       FontSize="22"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="SYSTEM STATUS"
                                       Foreground="{StaticResource CyberTextSecondaryBrush}"
                                       FontSize="10"
                                       Margin="1,2,0,0" />
                            <TextBlock x:Name="StatusText"
                                       Text="就绪"
                                       Foreground="{StaticResource CyberTextSecondaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="1,6,10,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="×"
                                Width="30"
                                Height="30"
                                Background="#2218274A"
                                BorderBrush="#5B77D8"
                                Foreground="{StaticResource CyberTextPrimaryBrush}"
                                Click="ClosePanel_Click" />
                    </Grid>

                    <TabControl Grid.Row="1"
                                Margin="0,14,0,0"
                                Style="{StaticResource CyberTabControlStyle}">
                        <TabItem Header="总览" Style="{StaticResource CyberTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="◆ 电脑状态"
                                               Style="{StaticResource CyberSectionTitleStyle}" />

                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CyberMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="CPU" Style="{StaticResource CyberMetricLabelStyle}" />
                                                <TextBlock x:Name="CpuText" Text="--" Style="{StaticResource CyberMetricValueStyle}" />
                                                <ProgressBar Height="5" Value="45" Maximum="100" Margin="0,10,0,0" Foreground="#2DE2FF" Background="#263D73" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource CyberMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="内存" Style="{StaticResource CyberMetricLabelStyle}" />
                                                <TextBlock x:Name="MemoryText" Text="--" Style="{StaticResource CyberMetricValueStyle}" />
                                                <ProgressBar Height="5" Value="62" Maximum="100" Margin="0,10,0,0" Foreground="#C084FC" Background="#263D73" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CyberMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="下载" Style="{StaticResource CyberMetricLabelStyle}" />
                                                <TextBlock x:Name="DownloadText" Text="--" Foreground="#38BDF8" FontSize="19" FontWeight="SemiBold" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="网卡实时接收" Foreground="#668AB6F9" FontSize="11" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource CyberMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="上传" Style="{StaticResource CyberMetricLabelStyle}" />
                                                <TextBlock x:Name="UploadText" Text="--" Foreground="#E879F9" FontSize="19" FontWeight="SemiBold" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="网卡实时发送" Foreground="#668AB6F9" FontSize="11" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CyberMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="磁盘" Style="{StaticResource CyberMetricLabelStyle}" />
                                                <TextBlock x:Name="DiskText" Text="--" Foreground="{StaticResource CyberTextPrimaryBrush}" FontSize="19" FontWeight="SemiBold" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
                                                <ProgressBar Height="5" Value="70" Maximum="100" Margin="0,10,0,0" Foreground="#60A5FA" Background="#263D73" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource CyberMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="温度" Style="{StaticResource CyberMetricLabelStyle}" />
                                                <TextBlock x:Name="TemperatureText" Text="--" Foreground="{StaticResource CyberTextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="传感器状态" Foreground="#668AB6F9" FontSize="11" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Style="{StaticResource CyberInfoPanelStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="54"
                                                    Height="54"
                                                    CornerRadius="8"
                                                    Background="#1F2252A3"
                                                    BorderBrush="#38BDF8"
                                                    BorderThickness="1"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="◇"
                                                           Foreground="#8B5CF6"
                                                           FontSize="28"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="HealthScoreText"
                                                           Text="健康分 --"
                                                           Foreground="{StaticResource CyberTextPrimaryBrush}"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                                <TextBlock x:Name="DiskWarningText"
                                                           Text="磁盘空间正常"
                                                           Foreground="#B6C8F7"
                                                           FontSize="12"
                                                           Margin="0,4,0,0" />
                                                <TextBlock x:Name="HealthReasonText"
                                                           Text="评分参考 CPU、内存、磁盘和高流量压力"
                                                           Foreground="{StaticResource CyberTextSecondaryBrush}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource CyberInfoPanelStyle}">
                                        <StackPanel>
                                            <TextBlock Text="◆ 功能入口"
                                                       Style="{StaticResource CyberSectionTitleStyle}" />
                                            <TextBlock Text="使用上方标签进入清理、网络、进程和报告工具。总览页只保留实时状态，避免把所有功能挤在一起。"
                                                       Foreground="{StaticResource CyberTextSecondaryBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="清理" Style="{StaticResource CyberTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <Border Style="{StaticResource CyberInfoPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="◆ 安全清理"
                                                   Style="{StaticResource CyberSectionTitleStyle}" />
                                        <WrapPanel Margin="0,0,0,6">
                                            <CheckBox x:Name="CleanupUserTempCheckBox"
                                                      Content="用户临时文件"
                                                      IsChecked="True"
                                                      Style="{StaticResource CyberCheckBoxStyle}" />
                                            <CheckBox x:Name="CleanupWindowsTempCheckBox"
                                                      Content="系统临时文件"
                                                      IsChecked="True"
                                                      Style="{StaticResource CyberCheckBoxStyle}" />
                                            <CheckBox x:Name="CleanupRecycleBinCheckBox"
                                                      Content="回收站"
                                                      IsChecked="False"
                                                      Style="{StaticResource CyberCheckBoxStyle}" />
                                        </WrapPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Content="扫描垃圾"
                                                    Grid.Column="0"
                                                    Height="34"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Margin="0,0,6,0"
                                                    Click="ScanCleanup_Click" />
                                            <Button Content="清理选中项"
                                                    Grid.Column="1"
                                                    Height="34"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Background="#7C3AED"
                                                    BorderBrush="#C084FC"
                                                    Margin="6,0,0,0"
                                                    Click="RunCleanup_Click" />
                                        </Grid>
                                        <TextBlock x:Name="CleanupSummaryText"
                                                   Text="先扫描，再勾选要清理的项目"
                                                   Foreground="{StaticResource CyberTextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,7" />
                                        <ListView x:Name="CleanupListView"
                                                  Height="250"
                                                  BorderBrush="#3659D4"
                                                  BorderThickness="1"
                                                  Background="#9908142B"
                                                  Foreground="{StaticResource CyberTextPrimaryBrush}">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
                                                    <Setter Property="Padding" Value="2" />
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              Margin="0,2"
                                                              Foreground="{StaticResource CyberTextPrimaryBrush}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="{StaticResource CyberTextPrimaryBrush}"
                                                                       FontSize="12"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding DetailText}"
                                                                       Foreground="{StaticResource CyberTextSecondaryBrush}"
                                                                       FontSize="11"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="网络" Style="{StaticResource CyberTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource CyberMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="下载速度" Style="{StaticResource CyberMetricLabelStyle}" />
                                                <TextBlock x:Name="NetworkDownloadText" Text="--" Foreground="#38BDF8" FontSize="21" FontWeight="SemiBold" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="所有网卡当前接收流量" Foreground="#668AB6F9" FontSize="11" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource CyberMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="上传速度" Style="{StaticResource CyberMetricLabelStyle}" />
                                                <TextBlock x:Name="NetworkUploadText" Text="--" Foreground="#E879F9" FontSize="21" FontWeight="SemiBold" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="所有网卡当前发送流量" Foreground="#668AB6F9" FontSize="11" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Border Style="{StaticResource CyberInfoPanelStyle}">
                                        <StackPanel>
                                            <TextBlock Text="◆ 速度说明"
                                                       Style="{StaticResource CyberSectionTitleStyle}" />
                                            <TextBlock Text="这里显示的是电脑当前实时网络流量，不是宽带最大测速。下载表示电脑每秒接收的数据量，上传表示电脑每秒发送的数据量。"
                                                       Foreground="{StaticResource CyberTextSecondaryBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Button Content="生成网络报告" Style="{StaticResource ActionButtonStyle}" Click="RunNetworkReport_Click" />
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="进程" Style="{StaticResource CyberTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <Border Style="{StaticResource CyberInfoPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="◆ 进程占用排行"
                                                   Style="{StaticResource CyberSectionTitleStyle}" />
                                        <TextBlock x:Name="ProcessRankingText"
                                                   Text="正在读取..."
                                                   Foreground="#C5D6FF"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,2" />
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="报告" Style="{StaticResource CyberTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" Content="生成电脑体检报告" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,7" Click="RunPcReport_Click" />
                                    <Button Grid.Row="0" Grid.Column="1" Content="生成网络报告" Style="{StaticResource ActionButtonStyle}" Margin="6,0,0,7" Click="RunNetworkReport_Click" />
                                    <Button Grid.Row="1" Grid.Column="0" Content="扫描 D:\ 文件夹占用" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,7" Click="RunFolderRadar_Click" />
                                    <Button Grid.Row="1" Grid.Column="1" Content="打开报告目录" Style="{StaticResource ActionButtonStyle}" Margin="6,0,0,7" Click="OpenReports_Click" />
                                    <Button Grid.Row="2" Grid.ColumnSpan="2" Content="退出" Style="{StaticResource ActionButtonStyle}" Background="#334155" BorderBrush="#64748B" Margin="0,0,0,0" Click="Exit_Click" />
                                </Grid>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>
