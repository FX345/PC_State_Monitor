<Window x:Class="PcGuardianLite.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PcGuardianLite"
        Width="920"
        Height="820"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <SolidColorBrush x:Key="CyberBaseBrush" Color="#07111F" />
        <Storyboard x:Key="CyberPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="BallPulseScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="1.018"
                             Duration="0:0:2.8" />
            <DoubleAnimation Storyboard.TargetName="BallPulseScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="1.018"
                             Duration="0:0:2.8" />
            <DoubleAnimation Storyboard.TargetName="BallOuterHalo"
                             Storyboard.TargetProperty="Opacity"
                             From="0.18"
                             To="0.42"
                             Duration="0:0:2.8" />
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Border x:Name="FloatingBall"
                Style="{StaticResource PremiumFloatingBallStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,4,20,0"
                MouseLeftButtonDown="FloatingBall_MouseLeftButtonDown"
                MouseMove="FloatingBall_MouseMove"
                MouseLeftButtonUp="FloatingBall_MouseLeftButtonUp">
            <Border.RenderTransform>
                <ScaleTransform x:Name="BallPulseScale" />
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource CyberPulseStoryboard}" />
                </EventTrigger>
            </Border.Triggers>
            <Border.ContextMenu>
                <ContextMenu Opened="FloatingBallContextMenu_Opened">
                    <MenuItem x:Name="PanelToggleMenuItem" Header="打开面板" Click="PanelToggleMenuItem_Click" />
                    <MenuItem x:Name="MonitorToggleMenuItem" Header="暂停监控" Click="MonitorToggleMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="显示内存" Click="DisplayMemoryMenuItem_Click" />
                    <MenuItem Header="显示 CPU" Click="DisplayCpuMenuItem_Click" />
                    <MenuItem Header="显示网速" Click="DisplayNetworkMenuItem_Click" />
                    <MenuItem Header="自动轮播" Click="DisplayAutoMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="透明度 95%" Click="Opacity95MenuItem_Click" />
                    <MenuItem Header="透明度 75%" Click="Opacity75MenuItem_Click" />
                    <MenuItem Header="透明度 55%" Click="Opacity55MenuItem_Click" />
                    <Separator />
                    <MenuItem Header="隐藏到托盘" Click="HideToTrayMenuItem_Click" />
                    <MenuItem Header="退出程序" Click="Exit_Click" />
                </ContextMenu>
            </Border.ContextMenu>
            <Grid>
                <Ellipse x:Name="BallOuterHalo"
                         Stroke="#5529C7E8"
                         StrokeThickness="2"
                         Margin="3"
                         Opacity="0.24" />
                <Ellipse Stroke="#6645D483" StrokeThickness="1" Margin="12" />
                <Ellipse Stroke="#443F4A59" StrokeThickness="1" Margin="22" />
                <Path Stroke="{StaticResource PremiumAccentBrush}"
                      StrokeThickness="2"
                      Opacity="0.82"
                      Data="M 33,20 A 42,42 0 0 1 88,32"
                      Stretch="None" />
                <StackPanel Width="94" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="BallMemoryText"
                               Text="内存 --"
                               Foreground="{StaticResource PremiumTextBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <Border Height="1"
                            Margin="16,8"
                            Background="{StaticResource PremiumLineStrongBrush}" />
                    <TextBlock x:Name="BallDownloadText"
                               Text="下载 --"
                               Foreground="{StaticResource PremiumTextMutedBrush}"
                               FontSize="12"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="DetailPanel"
                Width="860"
                MaxHeight="680"
                Margin="0,132,20,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="{StaticResource PremiumShellBrush}"
                BorderBrush="{StaticResource PremiumLineStrongBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="0"
                Opacity="1"
                RenderTransformOrigin="0.5,0"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PanelEntranceTransform" Y="0" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="8" Color="#020408" Opacity="0.58" />
            </Border.Effect>

            <Grid x:Name="PremiumShellGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="88" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="42" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#B80B1017"
                        BorderBrush="{StaticResource PremiumLineBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="8,8,0,0">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="电脑管家"
                                       Foreground="{StaticResource PremiumTextBrush}"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="SYSTEM STATUS"
                                           Foreground="{StaticResource PremiumTextMutedBrush}"
                                           FontSize="11" />
                                <Border Width="1" Height="12" Margin="12,0" Background="{StaticResource PremiumLineBrush}" />
                                <TextBlock x:Name="StatusText"
                                           Text="就绪"
                                           Foreground="{StaticResource PremiumTextMutedBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="420" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Style="{StaticResource PremiumStatusPillStyle}" Margin="0,0,14,0">
                                <TextBlock Text="MONITORING"
                                           Foreground="{StaticResource PremiumOkBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Button Content="×"
                                    Width="34"
                                    Height="34"
                                    Padding="0"
                                    Margin="0"
                                    Background="#151D27"
                                    BorderBrush="{StaticResource PremiumLineStrongBrush}"
                                    Foreground="{StaticResource PremiumTextBrush}"
                                    Style="{StaticResource PremiumButtonStyle}"
                                    Click="ClosePanel_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TabControl Grid.Row="1"
                            Style="{StaticResource PremiumNavigationTabControlStyle}"
                            ItemContainerStyle="{StaticResource PremiumNavigationTabItemStyle}">
                    <TabItem Header="总览">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="0,2,20,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid x:Name="MetricGrid" Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PremiumMetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="CPU" Style="{StaticResource PremiumLabelStyle}" />
                                            <TextBlock x:Name="CpuText" Text="--" Style="{StaticResource PremiumValueStyle}" />
                                            <ProgressBar Height="5" Value="45" Maximum="100" Foreground="{StaticResource PremiumAccentBrush}" Style="{StaticResource PremiumProgressBarStyle}" Margin="0,14,0,0" />
                                            <TextBlock Text="当前占用率" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="12" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PremiumMetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="内存" Style="{StaticResource PremiumLabelStyle}" />
                                            <TextBlock x:Name="MemoryText" Text="--" Style="{StaticResource PremiumValueStyle}" />
                                            <ProgressBar Height="5" Value="62" Maximum="100" Foreground="{StaticResource PremiumAccentAltBrush}" Style="{StaticResource PremiumProgressBarStyle}" Margin="0,14,0,0" />
                                            <TextBlock Text="物理内存使用" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="12" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PremiumMetricCardStyle}" Margin="0,0,0,18">
                                        <StackPanel>
                                            <TextBlock Text="磁盘" Style="{StaticResource PremiumLabelStyle}" />
                                            <TextBlock x:Name="DiskText" Text="--" Style="{StaticResource PremiumValueStyle}" />
                                            <ProgressBar Height="5" Value="70" Maximum="100" Foreground="{StaticResource PremiumWarnBrush}" Style="{StaticResource PremiumProgressBarStyle}" Margin="0,14,0,0" />
                                            <TextBlock Text="空间占用率" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="12" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PremiumMetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="下载" Style="{StaticResource PremiumLabelStyle}" />
                                            <TextBlock x:Name="DownloadText" Text="--" Foreground="{StaticResource PremiumAccentBrush}" FontSize="25" FontWeight="SemiBold" Margin="0,8,0,0" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="网卡实时接收" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="12" Margin="0,12,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PremiumMetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="上传" Style="{StaticResource PremiumLabelStyle}" />
                                            <TextBlock x:Name="UploadText" Text="--" Foreground="{StaticResource PremiumAccentAltBrush}" FontSize="25" FontWeight="SemiBold" Margin="0,8,0,0" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="网卡实时发送" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="12" Margin="0,12,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource PremiumMetricCardStyle}" Margin="0,0,0,18">
                                        <StackPanel>
                                            <TextBlock Text="温度" Style="{StaticResource PremiumLabelStyle}" />
                                            <TextBlock x:Name="TemperatureText" Text="--" Style="{StaticResource PremiumValueStyle}" FontSize="22" />
                                            <Border Style="{StaticResource PremiumStatusPillStyle}" Background="#182B3542" BorderBrush="{StaticResource PremiumLineStrongBrush}" Margin="0,14,0,0">
                                                <TextBlock Text="传感器状态" Foreground="{StaticResource PremiumTextMutedBrush}" FontSize="11" VerticalAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource PremiumModuleStyle}" Margin="0,0,18,18">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="96" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="76" Height="76" VerticalAlignment="Center">
                                                <Ellipse Stroke="{StaticResource PremiumLineStrongBrush}" StrokeThickness="5" />
                                                <Ellipse Stroke="{StaticResource PremiumAccentBrush}" StrokeThickness="5" StrokeDashArray="3 1.2" />
                                                <TextBlock x:Name="HealthScoreText"
                                                           Text="健康分 --"
                                                           Foreground="{StaticResource PremiumAccentBrush}"
                                                           FontSize="20"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center" />
                                            </Grid>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="健康评分" Style="{StaticResource PremiumSectionTitleStyle}" Margin="0,0,0,8" />
                                                <TextBlock x:Name="DiskWarningText" Text="磁盘空间正常" Foreground="{StaticResource PremiumTextBrush}" FontSize="14" />
                                                <TextBlock x:Name="HealthReasonText"
                                                           Text="评分参考 CPU、内存、磁盘和高流量压力"
                                                           Foreground="{StaticResource PremiumTextMutedBrush}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource PremiumModuleStyle}" Margin="0,0,0,18">
                                        <StackPanel>
                                            <TextBlock Text="工作流" Style="{StaticResource PremiumSectionTitleStyle}" />
                                            <TextBlock Text="概览保持安静，只显示关键状态。使用左侧导航进入清理、网络、进程和报告工具。"
                                                       Foreground="{StaticResource PremiumTextMutedBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                            <Border Style="{StaticResource PremiumStatusPillStyle}" Background="#1429C7E8" BorderBrush="#4429C7E8" Margin="0,16,0,0">
                                                <TextBlock Text="轻量运行 / 无广告 / 保守清理" Foreground="{StaticResource PremiumAccentBrush}" FontSize="11" VerticalAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="2" Style="{StaticResource PremiumModuleStyle}">
                                    <StackPanel>
                                        <TextBlock Text="模块入口" Style="{StaticResource PremiumSectionTitleStyle}" />
                                        <UniformGrid Columns="4">
                                            <TextBlock Text="清理优化" Foreground="{StaticResource PremiumTextMutedBrush}" FontSize="13" />
                                            <TextBlock Text="网络诊断" Foreground="{StaticResource PremiumTextMutedBrush}" FontSize="13" />
                                            <TextBlock Text="进程排行" Foreground="{StaticResource PremiumTextMutedBrush}" FontSize="13" />
                                            <TextBlock Text="报告输出" Foreground="{StaticResource PremiumTextMutedBrush}" FontSize="13" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="清理">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="0,2,20,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource PremiumModuleStyle}">
                                    <StackPanel>
                                        <TextBlock Text="安全清理" Style="{StaticResource PremiumSectionTitleStyle}" />
                                        <TextBlock Text="扫描前不会删除文件。清理项采用保守白名单策略，回收站需要额外确认。"
                                                   Foreground="{StaticResource PremiumTextMutedBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,16" />
                                        <WrapPanel>
                                            <CheckBox x:Name="CleanupUserTempCheckBox" Content="用户临时文件" IsChecked="True" Style="{StaticResource PremiumCheckBoxStyle}" />
                                            <CheckBox x:Name="CleanupWindowsTempCheckBox" Content="系统临时文件" IsChecked="True" Style="{StaticResource PremiumCheckBoxStyle}" />
                                            <CheckBox x:Name="CleanupRecycleBinCheckBox" Content="回收站" IsChecked="False" Style="{StaticResource PremiumCheckBoxStyle}" />
                                        </WrapPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="扫描垃圾" Style="{StaticResource PremiumPrimaryButtonStyle}" Margin="0,6,8,0" Click="ScanCleanup_Click" />
                                            <Button Grid.Column="1" Content="清理选中项" Style="{StaticResource PremiumButtonStyle}" Margin="8,6,0,0" Click="RunCleanup_Click" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Style="{StaticResource PremiumModuleStyle}">
                                    <StackPanel>
                                        <TextBlock x:Name="CleanupSummaryText"
                                                   Text="先扫描，再勾选要清理的项目"
                                                   Foreground="{StaticResource PremiumTextMutedBrush}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap" />
                                        <ProgressBar x:Name="CleanupActivityBar"
                                                     Style="{StaticResource TacticalActivityBarStyle}"
                                                     IsIndeterminate="True"
                                                     Visibility="Collapsed"
                                                     Margin="0,14,0,0" />
                                    </StackPanel>
                                </Border>
                                <ListView Grid.Row="2"
                                          x:Name="CleanupListView"
                                          Height="260"
                                          Style="{StaticResource PremiumListViewStyle}"
                                          ItemContainerStyle="{StaticResource PremiumListViewItemStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Foreground="{StaticResource PremiumTextBrush}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource PremiumTextBrush}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Row="1" Text="{Binding DetailText}" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="网络">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="0,2,20,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource PremiumMetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="下载速度" Style="{StaticResource PremiumLabelStyle}" />
                                            <TextBlock x:Name="NetworkDownloadText" Text="--" Foreground="{StaticResource PremiumAccentBrush}" FontSize="30" FontWeight="SemiBold" Margin="0,8,0,0" />
                                            <TextBlock Text="所有网卡当前接收流量" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="12" Margin="0,12,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource PremiumMetricCardStyle}" Margin="0,0,0,18">
                                        <StackPanel>
                                            <TextBlock Text="上传速度" Style="{StaticResource PremiumLabelStyle}" />
                                            <TextBlock x:Name="NetworkUploadText" Text="--" Foreground="{StaticResource PremiumAccentAltBrush}" FontSize="30" FontWeight="SemiBold" Margin="0,8,0,0" />
                                            <TextBlock Text="所有网卡当前发送流量" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="12" Margin="0,12,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Border Grid.Row="1" Style="{StaticResource PremiumModuleStyle}">
                                    <StackPanel>
                                        <TextBlock Text="网络说明" Style="{StaticResource PremiumSectionTitleStyle}" />
                                        <TextBlock Text="这里显示的是当前实时网络流量，不是宽带最大测速。下载表示电脑每秒接收的数据量，上传表示电脑每秒发送的数据量。"
                                                   Foreground="{StaticResource PremiumTextMutedBrush}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap" />
                                        <Button Content="生成网络报告" Style="{StaticResource PremiumPrimaryButtonStyle}" Width="180" HorizontalAlignment="Left" Click="RunNetworkReport_Click" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="进程">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Border Style="{StaticResource PremiumModuleStyle}" Margin="0,2,20,0">
                                <StackPanel>
                                    <TextBlock Text="进程占用排行" Style="{StaticResource PremiumSectionTitleStyle}" />
                                    <TextBlock Text="只查看占用排行，不结束进程。" Foreground="{StaticResource PremiumTextMutedBrush}" FontSize="12" Margin="0,0,0,12" />
                                    <Border Background="#78101820" BorderBrush="{StaticResource PremiumLineBrush}" BorderThickness="1" Padding="16">
                                        <TextBlock x:Name="ProcessRankingText"
                                                   Text="正在读取..."
                                                   Foreground="{StaticResource PremiumTextBrush}"
                                                   FontSize="13"
                                                   FontFamily="Consolas"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="报告">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Border Style="{StaticResource PremiumModuleStyle}" Margin="0,2,20,0">
                                <StackPanel>
                                    <TextBlock Text="报告与工具" Style="{StaticResource PremiumSectionTitleStyle}" />
                                    <TextBlock Text="生成本机状态、网络诊断和文件夹占用报告。报告目录可直接打开。"
                                               Foreground="{StaticResource PremiumTextMutedBrush}"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,16" />
                                    <UniformGrid Columns="2">
                                        <Button Content="生成电脑体检报告" Style="{StaticResource PremiumPrimaryButtonStyle}" Margin="0,0,8,10" Click="RunPcReport_Click" />
                                        <Button Content="生成网络报告" Style="{StaticResource PremiumButtonStyle}" Margin="8,0,0,10" Click="RunNetworkReport_Click" />
                                        <Button Content="扫描 D:\ 文件夹占用" Style="{StaticResource PremiumButtonStyle}" Margin="0,0,8,10" Click="RunFolderRadar_Click" />
                                        <Button Content="打开报告目录" Style="{StaticResource PremiumButtonStyle}" Margin="8,0,0,10" Click="OpenReports_Click" />
                                    </UniformGrid>
                                    <Button Content="退出程序" Style="{StaticResource PremiumButtonStyle}" Background="#251C2027" BorderBrush="{StaticResource PremiumDangerBrush}" Click="Exit_Click" />
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <Border Grid.Row="2"
                        Background="#AA0B1017"
                        BorderBrush="{StaticResource PremiumLineBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,8,8">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="CPU" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="12" />
                            <TextBlock Text="{Binding Text, ElementName=CpuText}" Foreground="{StaticResource PremiumTextMutedBrush}" FontSize="12" Margin="8,0,18,0" />
                            <TextBlock Text="内存" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="12" />
                            <TextBlock Text="{Binding Text, ElementName=MemoryText}" Foreground="{StaticResource PremiumTextMutedBrush}" FontSize="12" Margin="8,0,18,0" />
                            <TextBlock Text="磁盘" Foreground="{StaticResource PremiumTextWeakBrush}" FontSize="12" />
                            <TextBlock Text="{Binding Text, ElementName=DiskText}" Foreground="{StaticResource PremiumTextMutedBrush}" FontSize="12" Margin="8,0,18,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="v2.1.0"
                                   Foreground="{StaticResource PremiumTextWeakBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
