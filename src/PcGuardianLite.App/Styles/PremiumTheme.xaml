<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Design tokens for the restrained industrial instrument UI. -->
    <Color x:Key="PremiumColorBase">#090D12</Color>
    <Color x:Key="PremiumColorPanel">#111820</Color>
    <Color x:Key="PremiumColorPanelAlt">#151D27</Color>
    <Color x:Key="PremiumColorCard">#18212B</Color>
    <Color x:Key="PremiumColorCardSoft">#121922</Color>
    <Color x:Key="PremiumColorLine">#2B3542</Color>
    <Color x:Key="PremiumColorLineStrong">#3F4A59</Color>
    <Color x:Key="PremiumColorText">#F4F6F2</Color>
    <Color x:Key="PremiumColorTextMuted">#A7B0BC</Color>
    <Color x:Key="PremiumColorTextWeak">#6F7A88</Color>
    <Color x:Key="PremiumColorAccent">#29C7E8</Color>
    <Color x:Key="PremiumColorAccentAlt">#7C6DF2</Color>
    <Color x:Key="PremiumColorWarn">#F6A623</Color>
    <Color x:Key="PremiumColorDanger">#EF5B4B</Color>
    <Color x:Key="PremiumColorOk">#45D483</Color>

    <SolidColorBrush x:Key="PremiumBaseBrush" Color="{StaticResource PremiumColorBase}" />
    <SolidColorBrush x:Key="PremiumPanelBrush" Color="{StaticResource PremiumColorPanel}" />
    <SolidColorBrush x:Key="PremiumPanelAltBrush" Color="{StaticResource PremiumColorPanelAlt}" />
    <SolidColorBrush x:Key="PremiumCardBrush" Color="{StaticResource PremiumColorCard}" />
    <SolidColorBrush x:Key="PremiumLineBrush" Color="{StaticResource PremiumColorLine}" />
    <SolidColorBrush x:Key="PremiumLineStrongBrush" Color="{StaticResource PremiumColorLineStrong}" />
    <SolidColorBrush x:Key="PremiumTextBrush" Color="{StaticResource PremiumColorText}" />
    <SolidColorBrush x:Key="PremiumTextMutedBrush" Color="{StaticResource PremiumColorTextMuted}" />
    <SolidColorBrush x:Key="PremiumTextWeakBrush" Color="{StaticResource PremiumColorTextWeak}" />
    <SolidColorBrush x:Key="PremiumAccentBrush" Color="{StaticResource PremiumColorAccent}" />
    <SolidColorBrush x:Key="PremiumAccentAltBrush" Color="{StaticResource PremiumColorAccentAlt}" />
    <SolidColorBrush x:Key="PremiumWarnBrush" Color="{StaticResource PremiumColorWarn}" />
    <SolidColorBrush x:Key="PremiumDangerBrush" Color="{StaticResource PremiumColorDanger}" />
    <SolidColorBrush x:Key="PremiumOkBrush" Color="{StaticResource PremiumColorOk}" />

    <LinearGradientBrush x:Key="PremiumShellBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F00A0E13" Offset="0" />
        <GradientStop Color="#F2141C25" Offset="0.48" />
        <GradientStop Color="#F00D141D" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PremiumModuleBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EA1A2430" Offset="0" />
        <GradientStop Color="#DE121A23" Offset="0.68" />
        <GradientStop Color="#D80E151D" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PremiumCardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F11A242F" Offset="0" />
        <GradientStop Color="#E8141C26" Offset="0.58" />
        <GradientStop Color="#DC101820" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PremiumPrimaryButtonBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1C5C75" Offset="0" />
        <GradientStop Color="#173B62" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PremiumSubtleButtonBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#202A35" Offset="0" />
        <GradientStop Color="#18212A" Offset="1" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="PremiumBallBrush" GradientOrigin="0.35,0.25" Center="0.5,0.5" RadiusX="0.72" RadiusY="0.72">
        <GradientStop Color="#1A3646" Offset="0" />
        <GradientStop Color="#101B29" Offset="0.58" />
        <GradientStop Color="#070B10" Offset="1" />
    </RadialGradientBrush>

    <!-- Compatibility aliases used by existing UI tests and older XAML keys. -->
    <LinearGradientBrush x:Key="CyberPanelBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F20B0F14" Offset="0" />
        <GradientStop Color="#F2131820" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="TacticalAnimePanelBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F20B0F14" Offset="0" />
        <GradientStop Color="#F2131820" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="PremiumSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PremiumTextBrush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,14" />
    </Style>

    <Style x:Key="PremiumLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PremiumTextMutedBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PremiumValueStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PremiumTextBrush}" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="PremiumStatusPillStyle" TargetType="Border">
        <Setter Property="Height" Value="25" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="#1A45D483" />
        <Setter Property="BorderBrush" Value="#5545D483" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="PremiumModuleStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PremiumModuleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PremiumLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Margin" Value="0,0,0,18" />
    </Style>

    <Style x:Key="PremiumMetricCardStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="142" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Margin" Value="0,0,18,18" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{StaticResource PremiumCardGradientBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PremiumLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="0" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PremiumAccentBrush}" />
                <Setter Property="Background" Value="#F01C2834" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="-1" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CyberMetricCardStyle" TargetType="Border" BasedOn="{StaticResource PremiumMetricCardStyle}" />

    <Style x:Key="PremiumButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="42" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="Foreground" Value="{StaticResource PremiumTextBrush}" />
        <Setter Property="Background" Value="{StaticResource PremiumSubtleButtonBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PremiumLineStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                        <Grid>
                            <Border Width="3"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource PremiumAccentBrush}"
                                    Opacity="0.45" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonSurface" Property="BorderBrush" Value="{StaticResource PremiumAccentBrush}" />
                            <Setter TargetName="ButtonSurface" Property="Background" Value="#23303C" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.985" ScaleY="0.985" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonSurface" Property="BorderBrush" Value="{StaticResource PremiumWarnBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PremiumPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PremiumButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PremiumPrimaryButtonBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PremiumAccentBrush}" />
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PremiumButtonStyle}" />

    <Style x:Key="PremiumCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource PremiumTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="0,0,18,10" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="PremiumProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="5" />
        <Setter Property="Foreground" Value="{StaticResource PremiumAccentBrush}" />
        <Setter Property="Background" Value="#22313D4A" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="TacticalActivityBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource PremiumProgressBarStyle}">
        <Setter Property="Height" Value="6" />
        <Setter Property="Foreground" Value="{StaticResource PremiumWarnBrush}" />
    </Style>

    <Style x:Key="PremiumListViewStyle" TargetType="ListView">
        <Setter Property="Background" Value="#88101820" />
        <Setter Property="BorderBrush" Value="{StaticResource PremiumLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource PremiumTextBrush}" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style x:Key="PremiumListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PremiumTextBrush}" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1629C7E8" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PremiumScrollThumbStyle" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbSurface"
                            Width="7"
                            CornerRadius="4"
                            Background="#66798794" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbSurface" Property="Background" Value="{StaticResource PremiumAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbSurface" Property="Background" Value="{StaticResource PremiumWarnBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PremiumScrollbarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="11" />
        <Setter Property="Background" Value="#33090D12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Border Width="1"
                                HorizontalAlignment="Center"
                                Background="{StaticResource PremiumLineBrush}" />
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True"
                               Margin="2">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource PremiumScrollThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TacticalScrollBarStyle" TargetType="ScrollBar" BasedOn="{StaticResource PremiumScrollbarStyle}" />
    <Style TargetType="ScrollBar" BasedOn="{StaticResource PremiumScrollbarStyle}" />

    <Style x:Key="PremiumFloatingBallStyle" TargetType="Border">
        <Setter Property="Width" Value="118" />
        <Setter Property="Height" Value="118" />
        <Setter Property="CornerRadius" Value="59" />
        <Setter Property="Background" Value="{StaticResource PremiumBallBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PremiumAccentBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
    </Style>

    <Style x:Key="PremiumNavigationTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="TabStripPlacement" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="132" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="#A80B1118"
                                BorderBrush="{StaticResource PremiumLineBrush}"
                                BorderThickness="0,0,1,0"
                                Padding="14">
                            <TabPanel x:Name="HeaderPanel"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1" />
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          Margin="22,0,0,0"
                                          ContentSource="SelectedContent" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CyberTabControlStyle" TargetType="TabControl" BasedOn="{StaticResource PremiumNavigationTabControlStyle}" />

    <Style x:Key="PremiumNavigationTabItemStyle" TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource PremiumTextMutedBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="13,14" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="NavSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Border x:Name="TabSelectionRail"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource PremiumAccentBrush}"
                                    Opacity="0" />
                            <ContentPresenter ContentSource="Header"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource PremiumTextBrush}" />
                            <Setter TargetName="NavSurface" Property="Background" Value="#1929C7E8" />
                            <Setter TargetName="NavSurface" Property="BorderBrush" Value="#4429C7E8" />
                            <Setter TargetName="TabSelectionRail" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="NavSurface" Property="Background" Value="#101A222B" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
